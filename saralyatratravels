            -webkit-backdrop-filter: blur(20px);
        }

        .hero-section {
            position: relative;
            min-height: 75vh;
            display: flex;
            align-items: center;
            overflow: hidden;
            background: #000;
        }

        .hero-image-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            /* Photo of a vehicle on a winding road through green hills */
            background-image: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.7) 100%), url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&q=80&w=2000');
