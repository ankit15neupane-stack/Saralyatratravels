    <script>
        const PHONE = "9704270253";
        const RATE_PER_KM = 60; 
        const RATE_PER_DAY = 11999;
        let currentTripType = 'roundtrip';
        let currentSelectedPlace = null;

        const NEPAL_DATA = {
            "Pokhara": 202, "Chitwan": 168, "Lumbini": 285, "Gorkha": 142, "Mustang": 380,
            "Ilam": 475, "Janakpur": 224, "Hetauda": 85, "Birgunj": 145, "Biratnagar": 395,
            "Butwal": 265, "Bhairahawa": 280, "Nepalgunj": 515, "Dhangadhi": 660, "Mahendranagar": 705,
            "Dhulikhel": 30, "Nagarkot": 32, "Trishuli": 75, "Charikot": 133, "Bandipur": 148,
            "Tansen": 300, "Surkhet": 590, "Sindhuli": 150, "Khurkot": 100, "Jiri": 188,
            "Sauraha": 160, "Besisahar": 175, "Kalaiya": 130, "Gaur": 165, "Ghyangphedi": 95, "Bidur": 70
        };

        function setTripType(type) {
            currentTripType = type;
            const btnRound = document.getElementById('btn-roundtrip');
            const btnMulti = document.getElementById('btn-multiday');
            const dayContainer = document.getElementById('day-selector-container');
            const fareLabel = document.getElementById('fare-label');

            if(type === 'roundtrip') {
                btnRound.className = "flex items-center justify-center gap-3 py-4 rounded-xl border-2 border-emerald-500 bg-emerald-50 text-emerald-700 font-bold text-sm transition-all shadow-sm";
                btnMulti.className = "flex items-center justify-center gap-3 py-4 rounded-xl border-2 border-slate-100 bg-slate-50 text-slate-500 font-bold text-sm transition-all hover:bg-slate-100";
                dayContainer.classList.add('hidden');
                fareLabel.innerText = "Total Estimated Fare";
            } else {
                btnMulti.className = "flex items-center justify-center gap-3 py-4 rounded-xl border-2 border-emerald-500 bg-emerald-50 text-emerald-700 font-bold text-sm transition-all shadow-sm";
                btnRound.className = "flex items-center justify-center gap-3 py-4 rounded-xl border-2 border-slate-100 bg-slate-50 text-slate-500 font-bold text-sm transition-all hover:bg-slate-100";
                dayContainer.classList.remove('hidden');
                fareLabel.innerText = "Multi-Day Package Fare";
            }
        }

        function adjustDays(delta) {
            const input = document.getElementById('trip-days');
            let val = parseInt(input.value) + delta;
            if (val < 1) val = 1;
            if (val > 30) val = 30;
            input.value = val;
        }

        function searchPlaces(val) {
            const dropdown = document.getElementById('search-dropdown');
            const query = val.toLowerCase().trim();
            if(!query) { dropdown.classList.add('hidden'); return; }

            const matches = Object.keys(NEPAL_DATA).filter(p => p.toLowerCase().includes(query));

            if (matches.length > 0) {
                dropdown.innerHTML = matches.map(p => `
                    <div onclick="selectPlace('${p}')" class="px-6 py-4 hover:bg-slate-50 cursor-pointer transition flex justify-between items-center group">
                        <div class="flex items-center gap-4">
                            <i class="fas fa-location-dot text-slate-200 group-hover:text-emerald-500"></i>
                            <span class="font-bold text-slate-800">${p}</span>
                        </div>
                        <span class="text-[10px] font-black text-slate-400 italic">${NEPAL_DATA[p]} KM</span>
                    </div>
                `).join('');
                dropdown.classList.remove('hidden');
            } else {
                dropdown.innerHTML = `<div class="p-8 text-center text-slate-400 font-bold text-sm italic">City not found. Try another or contact us.</div>`;
                dropdown.classList.remove('hidden');
            }
        }

        function selectPlace(place) {
            currentSelectedPlace = place;
            document.getElementById('dest-search').value = place;
            document.getElementById('search-dropdown').classList.add('hidden');
        }

        function handleManualCalculation() {
            if(!currentSelectedPlace) {
                const searchBox = document.getElementById('dest-search');
                searchBox.classList.add('border-red-400');
                setTimeout(() => searchBox.classList.remove('border-red-400'), 500);
                return;
            }
            updateCalculation(currentSelectedPlace);
        }

        function updateCalculation(place) {
            const km = NEPAL_DATA[place];
            let fare = 0;
            let detailText = "";
            let rateLabelText = "";

            if (currentTripType === 'roundtrip') {
                fare = km * RATE_PER_KM * 2;
                detailText = (km * 2) + " KM (Round Trip)";
                rateLabelText = `Rs. ${RATE_PER_KM}/KM`;
            } else {
                const days = parseInt(document.getElementById('trip-days').value);
                fare = days * RATE_PER_DAY;
                detailText = `${days} Day(s) Package`;
                rateLabelText = `Rs. ${RATE_PER_DAY}/Day`;
            }

            document.getElementById('res-name').innerText = place;
            document.getElementById('res-distance').innerText = detailText;
            document.getElementById('res-rate-label').innerText = rateLabelText;
            document.getElementById('res-total-fare').innerText = "Rs. " + fare.toLocaleString();

            const container = document.getElementById('result-container');
            container.classList.remove('opacity-20', 'pointer-events-none', 'blur-[1px]');
            
            if(window.innerWidth < 1024) {
                container.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        function bookCalculatedTrip() {
            const pickup = document.getElementById('pickup-location').value || 'Kathmandu';
            const place = document.getElementById('res-name').innerText;
            const details = document.getElementById('res-distance').innerText;
            const fare = document.getElementById('res-total-fare').innerText;
            const type = currentTripType === 'roundtrip' ? 'Round-Trip' : 'Multi-Day';
            
            const msg = `Namaste Saral Yatra Travels! I want to book a ${type} trip.\nPick-up: ${pickup}\nDestination: ${place}\nDetails: ${details}\nEstimated Fare: ${fare}`;
            window.open(`https://wa.me/977${PHONE}?text=${encodeURIComponent(msg)}`, '_blank');
        }

        function bookNuwakotPackage(packageName, price) {
            const msg = `Namaste Saral Yatra Travels! I'm interested in the Nuwakot Package: ${packageName} for Rs. ${price.toLocaleString()}`;
            window.open(`https://wa.me/977${PHONE}?text=${encodeURIComponent(msg)}`, '_blank');
        }

        function directWhatsAppContact() {
            window.open(`https://wa.me/977${PHONE}?text=Hello Saral Yatra Travels! I want to inquire about EV trips.`, '_blank');
        }

        document.addEventListener('click', (e) => {
            if (!document.getElementById('dest-search').contains(e.target)) {
                document.getElementById('search-dropdown').classList.add('hidden');
            }
        });
    </script>
</body>
</html>
